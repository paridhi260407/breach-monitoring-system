# ==========================================
# BreachAlert - Global Environment Variables
# ==========================================

# SERVER CONFIGURATION
PORT=5000
NODE_ENV=development
CLIENT_URL=http://localhost:5173

# DATABASE (SQLite for local execution, or PostgreSQL)
DATABASE_URL=file:./dev.db

# REDIS CACHE
REDIS_URL=redis://localhost:6379

# AUTHENTICATION
JWT_SECRET=super_secret_breachalert_jwt_key_32_bytes_min_2026
JWT_EXPIRES_IN=7d

# HAVE I BEEN PWNED (HIBP) API
HIBP_API_KEY=mock
HIBP_USER_AGENT=BreachAlert-DataBreachMonitor/1.0

# EMAIL SERVICE CONFIGURATION (Nodemailer SMTP or SendGrid API)
EMAIL_FROM=no-reply@breachalert.io
EMAIL_FROM_NAME=BreachAlert Security Team

# GMAIL SMTP CONFIGURATION (Use Gmail App Password)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_gmail_app_password

# SENDGRID OPTION (Uncomment to use SendGrid instead of SMTP)
# SENDGRID_API_KEY=SG.your_sendgrid_api_key_here

# FRONTEND CONFIGURATION
VITE_API_BASE_URL=http://localhost:5000/api
